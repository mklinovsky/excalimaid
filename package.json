{
  "name": "excalimaid",
  "version": "1.0.9",
  "description": "Convert Mermaid diagrams to Excalidraw and open in browser. Includes MCP server for AI assistants.",
  "license": "MIT",
  "author": "Michal Klinovsky <michal.klinovsky@gmail.com>",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mklinovsky/excalimaid.git"
  },
  "keywords": [
    "mermaid",
    "excalidraw",
    "diagram",
    "mcp",
    "mcp-server"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "excalimaid": "dist/cli/cli.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && chmod +x dist/cli/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@excalidraw/mermaid-to-excalidraw": "^1.1.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18"
  }
}
